export GRAPHRAG_TOOLKIT_DIR=<Path to root of graphrag-toolkit repository on local machine>
export BUCKET_NAME=<Name of S3 bucket where test assets will be published>
export REGION_NAME=<Name of the AWS region in which to run the tests – should be the same as the bucket>

export ENV_TYPE=<OPTIONAL: Environment type – one of the EnvType param enums in the graphrag-toolkit-tests CFN template, default: neptune-db-aoss>
export NEPTUNE_ENGINE_VERSION=<OPTIONAL: Neptune engine version, for environments that host Neptune DB rather than Neptune Analytics, default: 1.4.7.0>
export DELETE_ON_PASS=<OPTIONAL: True|False - Delete the CFN stack if all tests pass, default: False>
export DELETE_STACK_ROLE=<OPTIONAL: ARN of an IAM role that allows deleting a CFN stack, default: Empty>
export ADDITIONAL_IAM_POLICY_ARN=<OPTIONAL: ARN of an additional IAM policy that will be attached to the SageMaker notebook, default: Empty>
export FAIL_FAST=<OPTIONAL: True|False – Whether or not to terminate testing and publish results as soon as one test fails, default: False>
export TOPIC=<OPTIONAL: Name of an SNS topic in the region in which the tests run to which test results will be published, default: Empty>
export TEST_EXTRACTION_LLM=<OPTIONAL: Model id or profile name of LLM to be used for extraction, default: us.anthropic.claude-sonnet-4-6>
export TEST_RESPONSE_LLM=<OPTIONAL: Model id or profile name of LLM to be used for responses, default: us.anthropic.claude-sonnet-4-6>
export EMBEDDINGS_MODEL=<OPTIONAL: Embeddings model id, e.g. us.cohere.embed-v4:0, default: Empty>
export EMBEDDINGS_DIMENSIONS=<OPTIONAL: Embeddings dimensions, e.g. 1536, default: Empty>
export DB_PASSWORD=<OPTIONAL: Database password – used by environments that require a database password (e.g. neo4j-aoss), default: auto-generated> 
