# Local Docker Environment Configuration
# Based on docker-compose.yml services

# AWS Configuration
AWS_PROFILE=default
AWS_REGION=us-east-1

# Graph Database
GRAPH_STORE=bolt://neo4j:password@neo4j:7687

# Vector Database (PostgreSQL)
VECTOR_STORE=postgresql://postgres:password@postgres:5432/graphrag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=graphrag

# Bedrock Models (https://docs.aws.amazon.com/bedrock/latest/userguide/model-lifecycle.html)
EXTRACTION_MODEL=us.anthropic.claude-sonnet-4-6
RESPONSE_MODEL=us.anthropic.claude-sonnet-4-6
EVALUATION_MODEL=us.anthropic.claude-sonnet-4-6
EMBEDDINGS_MODEL=cohere.embed-english-v3
EMBEDDINGS_DIMENSIONS=1024

# Extraction Configuration
EXTRACTION_NUM_WORKERS=2
EXTRACTION_NUM_THREADS_PER_WORKER=4
EXTRACTION_BATCH_SIZE=4

# Build Configuration
BUILD_NUM_WORKERS=2
BUILD_BATCH_SIZE=4
BUILD_BATCH_WRITE_SIZE=25
BATCH_WRITES_ENABLED=True

# Feature Flags
ENABLE_CACHE=False
# Include domain labels in entity identifiers
INCLUDE_DOMAIN_LABELS=False

# S3 Buckets
LOCAL_EXTRACT_S3=ccms-lexical-graph
PROMPT_S3=ccms-lexical-graph

# GitLab Registry Credentials
GITLAB_PYPI_TOKEN="your-gitlab-token-here"
GITLAB_USERNAME="your-gitlab-username"

# Tenant Configuration
TENANT_ID=default

# Application Configuration
APPLICATION_ID=lexical-graph-local-dev
